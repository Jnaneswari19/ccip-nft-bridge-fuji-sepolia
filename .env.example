# ===========================
# Environment Variables
# ===========================

# Private key of your deployer wallet (DO NOT commit your real key!)
PRIVATE_KEY=0xYourPrivateKeyHere

# RPC URLs
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<your-infura-key>

# Explorer API Keys
SNOWTRACE_API_KEY=your-snowtrace-api-key
ETHERSCAN_API_KEY=your-etherscan-api-key

# Router addresses (replace with actual CCIP router addresses)
ROUTER_FUJI=0xRouterAddressOnFuji
ROUTER_SEPOLIA=0xRouterAddressOnSepolia

# NFT contract addresses (after deployment, paste them here)
NFT_FUJI=0xCrossChainNFTAddressOnFuji
NFT_SEPOLIA=0xCrossChainNFTAddressOnSepolia
